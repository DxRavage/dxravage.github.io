---
import MainLayout from "../../layouts/MainLayout.astro";
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<MainLayout
  title={t('about.title')}
  description={t('about.desc')}
>
  <div
    class="flex flex-col items-center p-4 md:flex-row md:items-start md:pb-12 md:pt-24 md:max-w-4xl md:mx-auto"
  >
    <h1
      class="text-4xl flex flex-col pt-14 pb-4 text-rose items-center gap-x-2 font-mechsuit"
      transition:name="myname"
    >
      {t('about.h1')} <span class="text-primary">{t('about.h1Span')}</span>
    </h1>

    <section class="flex justify-center md:justify-start pt-8 pl-12">
      <div class="flex flex-col gap-4">
        <p class="font-bold text-sm hidden lg:flex">
          {t('about.p1')}
        </p>
        <p class="text-xs hidden lg:flex">
          {t('about.p2')}
        </p>
      </div>
    </section>
  </div>

  <section class="flex justify-center px-8">
    <article id="about">
      <section class="text-primary space-y-4">
        <p class="font-bold text-sm md:text-base lg:hidden">
          {t('about.p1')}
        </p>

        <p class="text-sm lg:hidden pb-4">
          {t('about.p2')}
        </p>
      </section>

      <section
        class="flex flex-col md:flex-row text-primary pt-12 border-t-2 border-zinc w- gap-8"
      >
        <ul class="text-xs">
          <li class="font-bold text-sm mb-1">
            {t('about.edu')} <span class="text-rose flex flex-col">-</span>
          </li>
          <li>Universidad Autonoma del Noreste</li>
          <li>Software Engineering</li>
          <li>2025</li>
        </ul>

        <div>
          <ul class="text-xs">
            <li class="font-bold text-sm">
              {t('about.exp')} <span class="text-rose flex flex-col">-</span>
            </li>
            <li>
              <li class="text-md font-bold">Technology Support Analyst</li>
              <li>Qualfon | Allstate</li>
              <li>Incident Management</li>
              <li class="font-light">
                Diagnosing and resolving a wide range of technical issues
                including troubleshooting and resolving hardware, software, and
                network issues.
              </li>
            </li>

            <li class="text-md font-bold pt-4">Senior Trainer</li>
            <li>Qualfon | Allstate</li>
            <li>
              Leading Trainees remotely for Mexico, Colombia and Philippines.
            </li>
            <li>
              Conducted QA and coaching sessions to ensure goal attainment
              through the use of SMART goals.
            </li>
          </ul>
        </div>

        <ul class="text-xs">
          <li class="font-bold text-sm">
            {t('about.tskill')} <span class="text-rose flex flex-col">-</span><li>
              <li>Astro</li>
              <li>Typescript</li>
              <li>Tailwind CSS</li>
              <li>CSS3 + HTML5</li>
              <li>MySQL</li>
              <li>React</li>
              <li>Rest API</li>
            </li>
          </li>
        </ul>

        <ul class="text-xs">
          <li class="font-bold text-sm mb-1">
            {t('about.dskill')}<span class="text-rose flex flex-col">-</span>
          </li>
          <li>UI/UX</li>
          <li>Wireframing & Prototyping</li>
          <li>Design Thinking</li>
          <li>Design Research</li>
        </ul>
      </section>
    </article>
  </section></MainLayout
>
<style>
  ul {
    max-width: 400px;
  }
  li {
    padding-bottom: 4px;
  }
</style>
