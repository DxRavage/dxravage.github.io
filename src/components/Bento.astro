---
import Project from "@components/Project.astro";
import { projectsData } from "../data/projects";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-14 md:p-14">
  <div class="flex flex-col items-center mb-12">
    <h2 class="font-mechsuit text-rose text-2xl text-center uppercase tracking-[0.2em] relative">
      {t('bento.title')}
      <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 flex gap-1 h-1 w-24">
        <div class="flex-1 bg-rose/20"></div>
        <div class="w-4 bg-rose shadow-[0_0_8px_rgba(225,29,72,0.4)]"></div>
        <div class="flex-1 bg-rose/20"></div>
      </div>
    </h2>
  </div>

  <section class="grid grid-cols-1 lg:grid-cols-3 lg:px-28">
    {projectsData.map((project) => (
      <Project
        title={project.title}
        description={project.description[lang]}
        imgSrc={project.imgSrc}
        link={project.link}
      />
    ))}
  </section>
</section>
