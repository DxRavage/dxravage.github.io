---
import { Image } from "astro:assets";
import { getLangFromUrl } from '../i18n/utils';

const { title, description, imgSrc, link } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const currentDesc = typeof description === 'string' ? description : (description[lang] || description.en);
const localizedLink = lang === 'es' && link.startsWith('/') && !link.startsWith('/es') ? `/es${link}` : link;
---

<section class="group">
  <div class="mecha-panel border border-blue-600/30 dark:border-blue-400/20 bg-zinc-900 hover:border-rose/60 transition-all duration-500 relative overflow-hidden h-80 shadow-lg">
    
    <a href={localizedLink} rel="noopener noreferrer" class="block h-full relative">
      
      <Image
        src={imgSrc}
        alt={title}
        class="absolute inset-0 object-cover object-center w-full h-full 
               transition-all duration-700 
               opacity-90 
               group-hover:opacity-10 
               group-hover:scale-105 
               group-hover:grayscale 
               group-hover:blur-[4px]" 
        width="1200"
        height="600"
        loading="lazy"
      />

      <div class="absolute inset-0 bg-zinc-100 dark:bg-zinc-950 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10"></div>

      <div class="relative z-20 h-full w-full flex flex-col justify-end p-6">
        
        <div class="group-hover:opacity-0 group-hover:pointer-events-none transition-opacity duration-300 opacity-50">
           <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-black/90 to-transparent -z-10"></div>
           <h3 class="text-xl text-white font-mechsuit drop-shadow-lg tracking-wider">
             {title}
           </h3>
        </div>

        <div class="absolute bottom-6 left-6 right-6 flex flex-col opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-500">
           <div class="text-[9px] text-rose font-mono mb-1 tracking-[0.2em] uppercase animate-pulse">
             PROJECT_LOG // ACCESS_GRANTED
           </div>
           
           <h3 class="text-3xl text-rose font-mechsuit leading-none uppercase pb-1 border-b border-rose/30 mb-4">
             {title}
           </h3>
           
           <div class="bg-rose/[0.03] border-l-2 border-rose/50 pl-4 mb-6">
             <p class="text-[13px] md:text-sm text-zinc-900 dark:text-zinc-50 font-michroma leading-relaxed line-clamp-4 italic">
               {currentDesc}
             </p>
           </div>

           <div class="flex items-center justify-between text-[10px] font-mono text-rose/70 mb-4">
             <span class="font-bold">VIEW_DETAILS</span>
             <span class="tracking-widest opacity-40">>>>>></span>
           </div>

           <div class="h-1 w-full bg-rose/10 overflow-hidden relative mt-auto">
             <div class="absolute inset-0 bg-rose shadow-[0_0_10px_rgba(225,29,72,0.6)] origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-700 ease-out delay-300"></div>
           </div>
        </div>
      </div>
    </a>
  </div>
</section>