---
import { Image } from "astro:assets";
import { getLangFromUrl } from '../i18n/utils';

const { title, description, imgSrc, link } = Astro.props;
const lang = getLangFromUrl(Astro.url);

// Handle both pre-resolved strings (from Bento) and description objects (from ProjectsGallery)
const currentDesc = typeof description === 'string' ? description : (description[lang] || description.en);
const localizedLink = lang === 'es' && link.startsWith('/') && !link.startsWith('/es') ? `/es${link}` : link;
---

<section class="group">
  <div class="mecha-panel border border-blue-600/30 dark:border-blue-400/20 bg-zinc-500/5 hover:border-rose/60 transition-all duration-500 relative overflow-hidden h-80">
    <!-- Industrial Markings -->
    <div class="absolute top-0 right-0 bg-zinc-500/10 text-[8px] px-2 py-1 font-mono z-20 opacity-40 group-hover:opacity-100 group-hover:text-rose transition-all uppercase tracking-tighter">PRJ_FILE // 0xAF42</div>
    
    <a href={localizedLink} rel="noopener noreferrer" title="Project Website" class="block h-full">
      <div class="relative h-full w-full overflow-hidden">
        <Image
          src={imgSrc}
          alt={title}
          class="absolute inset-0 object-cover object-center w-full h-full group-hover:scale-110 group-hover:rotate-1 transition-all duration-700 opacity-80 group-hover:opacity-60"
          width="1200"
          height="600"
          loading="lazy"
        />
        
        <!-- Hover Overlay -->
        <div
          class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-all duration-500 backdrop-blur-md bg-zinc-100/98 dark:bg-zinc-950/90"
        >
          <div class="flex flex-col justify-end h-full p-6">
            <div class="translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
               <div class="text-[9px] text-rose font-mono mb-1 tracking-[0.2em] animate-pulse">SCANNING COMPLETE_</div>
               <h3 class="text-2xl text-rose font-mechsuit pb-2 drop-shadow-md">{title}</h3>
               <p class="text-[11px] md:text-xs text-zinc-900 dark:text-zinc-100 font-medium leading-relaxed max-w-[90%]">
                 {currentDesc}
               </p>
               <!-- Progress indicator -->
               <div class="mt-4 flex gap-1 h-0.5 w-full">
                 <div class="w-1/3 bg-rose"></div>
                 <div class="w-1/3 bg-rose/30"></div>
                 <div class="flex-1 bg-zinc-500/20"></div>
               </div>
            </div>
          </div>
        </div>
      </div>
    </a>
  </div>
</section>
