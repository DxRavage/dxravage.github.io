---
import { Image } from "astro:assets";
import { getLangFromUrl } from '../i18n/utils';

const { title, description, imgSrc, link } = Astro.props;
const lang = getLangFromUrl(Astro.url);

// Handle both pre-resolved strings (from Bento) and description objects (from ProjectsGallery)
const currentDesc = typeof description === 'string' ? description : (description[lang] || description.en);
const localizedLink = lang === 'es' && link.startsWith('/') && !link.startsWith('/es') ? `/es${link}` : link;
---

<section>
  <div>
    <a href={localizedLink} rel="noopener noreferrer" title="Project Website">
      <div class="relative bg-opacity-35 group h-96 overflow-hidden">
        <Image
          src={imgSrc}
          alt={title}
          class="absolute inset-0 object-contain object-center w-full h-full group-hover:opacity-75 transition-opacity duration-300"
          width="1200"
          height="600"
          loading="lazy"
        />
        <div
          class="absolute inset-0 md:opacity-0 cursor-pointer group-hover:opacity-100 transition-opacity duration-200"
        >
          <div class="flex items-end h-full bg-zinc-200/95 dark:bg-zinc-950/95 backdrop-blur-sm">
            <div class="p-4">
              <h2 class="text-xl text-rose font-bold pb-4">{title}</h2>
              <p class="text-xs text-zinc-900 dark:text-white font-medium drop-shadow-sm">{currentDesc}</p>
            </div>
          </div>
        </div>
      </div>
    </a>
  </div>
</section>
