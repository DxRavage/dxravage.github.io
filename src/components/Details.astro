---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const titleParts = t('details.title').split(' ');
const firstWord = titleParts[0];
const restOfTitle = titleParts.slice(1).join(' ');
---

<style>
  .mecha-clip {
    clip-path: polygon(0 0, 96% 0, 100% 12%, 100% 100%, 4% 100%, 0 88%);
  }
  
  details[open] .content-animate {
    animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Variación de color para secciones de Soporte/Diagnóstico */
  .border-l-diagnostic {
    border-left-color: rgba(245, 158, 11, 0.2); /* Ámbar suave */
  }
  details[open].border-l-diagnostic {
    border-left-color: #f59e0b; /* Ámbar sólido */
  }
</style>

<div class="py-10 md:py-20 mb-14 mx-auto max-w-screen-xl text-center mecha-grid relative">
  <div class="flex flex-col items-center space-y-8 relative z-10">
    
    <div class="border-l-4 border-rose pl-4 py-4 mb-4 md:mb-8">
      <h2 class="font-mechsuit text-rose text-md md:text-3xl uppercase text-left">
        {firstWord} <span style="color: var(--color-primary)">{restOfTitle}</span>
      </h2>
    </div>

    <div class="w-full max-w-3xl space-y-6 px-4">
      
      {/* --- ITEM 01: SOFTWARE ENGINEERING --- */}
      <details class="group w-full mecha-panel bg-zinc-950/40 border-y border-r border-white/5 transition-all duration-500 border-l-4 border-l-blue-600/20 open:border-l-rose open:bg-zinc-900/60 mecha-clip" open>
        <summary class="cursor-pointer p-6 list-none flex justify-between items-center outline-none">
          <div class="flex items-center gap-4">
            <div class="w-2 h-8 bg-blue-600/10 group-open:bg-rose group-hover:scale-y-110 transition-all"></div>
            <span class="text-xl font-mechsuit tracking-widest uppercase group-open:text-rose transition-colors" style="color: var(--color-primary)">
              {t('edu.uane.degree')}
            </span>
          </div>
          <div class="text-right hidden sm:block">
            <span class="text-[9px] font-mono block opacity-40 text-rose tracking-tighter uppercase">Sync_Active</span>
            <span class="text-xs font-mono text-rose font-bold">QUAL_SYS // 01</span>
          </div>
        </summary>
        
        <div class="p-6 pt-0 content-animate text-left">
          <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row gap-6">
            <div class="flex-1 space-y-5">
              <div class="inline-block px-3 py-1 bg-rose/5 border border-white/10 text-[11px] font-mono text-rose uppercase tracking-wider">
                TIMELINE: 2021-2025 // STATUS: COMPLETED
              </div>
              <p class="text-sm md:text-base leading-relaxed font-michroma opacity-90" style="color: var(--color-primary)">
                {t('details.exp1Desc')}
              </p>
              <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-rose/50 font-mono">
                {t('edu.label.inst')}: {t('edu.uane')}
              </p>
            </div>
            <div class="flex items-center justify-center w-32 h-20 p-2 bg-white/5 border border-white/5 rounded-lg group-hover:border-rose/20 transition-all self-center md:self-start overflow-hidden">
              <img src="/assets/logos/logo-uane.png" alt="UANE Logo" class="max-w-full max-h-full object-contain grayscale opacity-30 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700" />
            </div>
          </div>
          <div class="mt-6 h-[2px] w-full bg-white/5 overflow-hidden">
            <div class="h-full bg-rose/40 w-full origin-left scale-x-0 group-open:scale-x-100 transition-transform duration-1000 delay-300"></div>
          </div>
        </div>
      </details>

      {/* --- ITEM 02: UX DESIGN --- */}
      <details class="group w-full mecha-panel bg-zinc-950/40 border-y border-r border-white/5 transition-all duration-500 border-l-4 border-l-blue-600/20 open:border-l-rose open:bg-zinc-900/60 mecha-clip">
        <summary class="cursor-pointer p-6 list-none flex justify-between items-center outline-none">
          <div class="flex items-center gap-4">
            <div class="w-2 h-8 bg-blue-600/10 group-open:bg-rose group-hover:scale-y-110 transition-all"></div>
            <span class="text-xl font-mechsuit tracking-widest uppercase group-open:text-rose transition-colors" style="color: var(--color-primary)">
              {t('edu.google')}
            </span>
          </div>
          <div class="text-right hidden sm:block">
            <span class="text-[9px] font-mono block opacity-40 text-rose tracking-tighter uppercase">Stream_Link</span>
            <span class="text-xs font-mono text-rose font-bold">QUAL_SYS // 02</span>
          </div>
        </summary>
        
        <div class="p-6 pt-0 content-animate text-left">
           <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row gap-6">
              <div class="flex-1 space-y-5">
                <div class="inline-block px-3 py-1 bg-rose/5 border border-white/10 text-[11px] font-mono text-rose uppercase tracking-wider">
                  TIMELINE: 2025 // STATUS: COMPLETED
                </div>
                <p class="text-sm md:text-base font-michroma opacity-90" style="color: var(--color-primary)">{t('details.exp2Desc')}</p>
                <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-rose/50 font-mono">{t('edu.label.prov')}: {t('edu.google.cert')}</p>
              </div>
              <a href="https://coursera.org/share/5539e71b64718710ae4b3d6b4eff01ed" target="_blank" class="flex items-center justify-center w-32 h-20 p-4 bg-white/5 hover:bg-rose/5 border border-white/10 hover:border-rose/20 transition-all rounded-lg self-center md:self-start overflow-hidden">
                <img src="/assets/logos/logo-google.svg" alt="Google logo" class="max-w-full max-h-full object-contain opacity-30 group-hover:opacity-100 transition-all duration-700" />
              </a>
           </div>
           <div class="mt-6 h-[2px] w-full bg-white/5 overflow-hidden">
            <div class="h-full bg-rose/40 w-full origin-left scale-x-0 group-open:scale-x-100 transition-transform duration-1000 delay-300"></div>
          </div>
        </div>
      </details>

      {/* --- ITEM 03: BACK-END --- */}
      <details class="group w-full mecha-panel bg-zinc-950/40 border-y border-r border-white/5 transition-all duration-500 border-l-4 border-l-blue-600/20 open:border-l-rose open:bg-zinc-900/60 mecha-clip">
        <summary class="cursor-pointer p-6 list-none flex justify-between items-center outline-none">
          <div class="flex items-center gap-4">
            <div class="w-2 h-8 bg-blue-600/10 group-open:bg-rose group-hover:scale-y-110 transition-all"></div>
            <span class="text-xl font-mechsuit tracking-widest uppercase group-open:text-rose transition-colors" style="color: var(--color-primary)">
              {t('edu.oracle')}
            </span>
          </div>
          <div class="text-right hidden sm:block">
            <span class="text-[9px] font-mono block opacity-40 text-rose tracking-tighter uppercase">Arch_Index</span>
            <span class="text-xs font-mono text-rose font-bold">QUAL_SYS // 03</span>
          </div>
        </summary>
        
        <div class="p-6 pt-0 content-animate text-left">
           <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row gap-6">
              <div class="flex-1 space-y-5">
                <div class="inline-block px-3 py-1 bg-rose/5 border border-white/10 text-[11px] font-mono text-rose uppercase tracking-wider">
                  TIMELINE: 2023 // STATUS: COMPLETED
                </div>
                <p class="text-sm md:text-base font-michroma opacity-90" style="color: var(--color-primary)">{t('details.exp3Desc')}</p>
                <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-rose/50 font-mono">{t('edu.label.prog')}: {t('edu.oracle.cert')}</p>
              </div>
              <a href="https://app.aluracursos.com/program/certificate/10f8b864-3701-4f07-9fd8-bce0be82d299" target="_blank" class="flex items-center justify-center w-32 h-20 p-4 bg-white/5 hover:bg-rose/5 border border-white/10 hover:border-rose/20 transition-all rounded-lg self-center md:self-start overflow-hidden">
                <img src="/assets/logos/logo-oracle.svg" alt="Oracle Logo" class="max-w-full max-h-full object-contain opacity-30 group-hover:opacity-100 transition-all duration-700" />
              </a>
           </div>
           <div class="mt-6 h-[2px] w-full bg-white/5 overflow-hidden">
            <div class="h-full bg-rose/40 w-full origin-left scale-x-0 group-open:scale-x-100 transition-transform duration-1000 delay-300"></div>
          </div>
        </div>
      </details>

    </div>
  </div>
</div>