---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="py-20 mb-14 mx-auto max-w-screen-xl text-center mecha-grid">
  <div class="flex flex-col items-center space-y-6">
    <h2 class="font-mechsuit text-rose text-2xl pb-8 tracking-widest">
      {t('details.title').split(' ')[0]} <span class="text-primary">{t('details.title').split(' ').slice(1).join(' ')}</span>
    </h2>

    <div class="w-full max-w-2xl space-y-4 px-4">
      <details
        class="group w-full mecha-panel bg-zinc-500/5 border border-blue-600/30 dark:border-blue-400/20 p-6 transition-all duration-300 open:border-rose/30"
        open
      >
        <summary
          class="cursor-pointer text-lg font-mechsuit tracking-wider text-left list-none flex justify-between items-center group-hover:text-rose"
        >
          <span>Software Engineering</span>
          <span class="text-[10px] font-mono opacity-80 text-rose font-bold">QUAL_SYS // 01</span>
        </summary>
        
        <div class="text-left mt-6 relative border-t border-blue-600/30 dark:border-blue-400/20 pt-4">
          <p class="text-[10px] text-rose font-mono mb-2">COMPLETION_DATE: 2025</p>
          <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <p class="text-sm leading-relaxed max-w-lg">{t('details.exp1Desc')}</p>
            <img
              src="/assets/logos/logo-uane.png"
              alt="UANE Logo"
              class="w-24 h-auto opacity-80 grayscale group-hover:grayscale-0 transition-all"
            />
          </div>
          <p class="mt-4 text-[10px] uppercase tracking-widest opacity-80 text-rose/80 font-mono">
            Institution: Universidad Autonoma del Noreste
          </p>
        </div>
      </details>

      <details class="group w-full mecha-panel bg-zinc-500/5 border border-blue-600/30 dark:border-blue-400/20 p-6 transition-all duration-300 open:border-rose/30 outline-none">
        <summary
          class="cursor-pointer text-lg font-mechsuit tracking-wider text-left list-none flex justify-between items-center group-hover:text-rose"
        >
          <span>UX Design - Google</span>
          <span class="text-[10px] font-mono opacity-80 text-rose font-bold">QUAL_SYS // 02</span>
        </summary>
        
        <div class="text-left mt-6 relative border-t border-blue-600/30 dark:border-blue-400/20 pt-4">
          <p class="text-[10px] text-rose font-mono mb-2">COMPLETION_DATE: 2025</p>
          <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <p class="text-sm leading-relaxed max-w-lg">{t('details.exp2Desc')}</p>
            <a
              href="https://coursera.org/share/5539e71b64718710ae4b3d6b4eff01ed"
              target="_blank"
              rel="noopener"
              class="p-2 border border-blue-600/30 dark:border-blue-400/20 bg-zinc-500/5 hover:bg-rose/10 transition-all mecha-panel-alt" 
            >
              <img
                src="/assets/logos/logo-google.svg"
                alt="Google logo"
                class="w-10 h-auto opacity-80"
              />
            </a>
          </div>
          <p class="mt-4 text-[10px] uppercase tracking-widest opacity-80 text-rose/80 font-mono">
            Provider: Google Professional Certificate
          </p>
        </div>
      </details>

      <details class="group w-full mecha-panel bg-zinc-500/5 border border-blue-600/30 dark:border-blue-400/20 p-6 transition-all duration-300 open:border-rose/30 outline-none">
        <summary
          class="cursor-pointer text-lg font-mechsuit tracking-wider text-left list-none flex justify-between items-center group-hover:text-rose"
        >
          <span>Back-End - Oracle</span>
          <span class="text-[10px] font-mono opacity-80 text-rose font-bold">QUAL_SYS // 03</span>
        </summary>
        
        <div class="text-left mt-6 relative border-t border-blue-600/30 dark:border-blue-400/20 pt-4">
          <p class="text-[10px] text-rose font-mono mb-2">COMPLETION_DATE: 2023</p>
          <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <p class="text-sm leading-relaxed max-w-lg">{t('details.exp3Desc')}</p>
            <a
              href="https://app.aluracursos.com/program/certificate/10f8b864-3701-4f07-9fd8-bce0be82d299"
              target="_blank"
              rel="noopener"
              class="p-2 border border-blue-600/30 dark:border-blue-400/20 bg-zinc-500/5 hover:bg-rose/10 transition-all mecha-panel-alt" 
            >
              <img
                src="/assets/logos/logo-oracle.svg"
                alt="Oracle Logo"
                class="w-10 h-auto opacity-80"
              />
            </a>
          </div>
          <p class="mt-4 text-[10px] uppercase tracking-widest opacity-80 text-rose/80 font-mono">
            Program: Oracle Next Education
          </p>
        </div>
      </details>
    </div>
  </div>
</div>
