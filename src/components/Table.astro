---
import Typescript from "../components/svg/Core.astro";
import AstroIcon from "../components/svg/SysFramework.astro";
import React from "../components/svg/RenderEngine.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="table"
  class="relative mx-auto w-[95%] md:w-3/4 flex flex-col lg:flex-row mt-24 py-32 text-pretty gap-8 md:gap-4 mecha-grid"
>
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none">
     <div class="absolute top-0 left-1/4 w-px h-full bg-zinc-500"></div>
     <div class="absolute top-0 right-1/4 w-px h-full bg-zinc-500"></div>
  </div>

  <div class="flex-1 p-8 mecha-panel bg-zinc-500/5 border border-blue-600/30 dark:border-blue-400/20 relative group hover:border-rose/30 transition-all duration-500 backdrop-blur-sm">
    <div class="absolute top-0 left-0 bg-rose text-[9px] px-3 py-1 text-white font-mono tracking-tighter z-10 shadow-[4px_4px_0_rgba(225,29,72,0.2)]">UNIT_01 // STACK</div>
    
    <div class="flex flex-row items-center border-b border-blue-600/30 dark:border-blue-400/20 pb-6 mb-2">
      <div class="p-2 bg-zinc-500/5 mecha-panel-alt border border-blue-600/30 dark:border-blue-400/20 group-hover:scale-110 transition-transform">
        <React />
      </div>
      <h2 class="text-rose dark:text-rose align-middle text-md md:text-xl pl-6 tracking-wide uppercase">
        {t('about.unit1')}
      </h2>
    </div>
    
    <div class="py-2 text-[10px] text-rose/50 font-mono uppercase tracking-widest mb-4">Functional Status: Operational</div>
    
    <p class="text-primary text-sm leading-relaxed opacity-80">
      {t('table.reactDesc')}
    </p>

    <div class="mt-8 flex items-end gap-1.5 h-6">
      <div class="w-12 h-1 bg-rose shadow-[0_0_10px_rgba(225,29,72,0.3)]"></div>
      <div class="w-3 h-1 bg-gold"></div>
      <div class="flex-1 h-[1px] bg-zinc-500/30 mb-[1.5px]"></div>
    </div>
  </div>

  <div class="flex-1 p-8 mecha-panel bg-zinc-500/5 border border-blue-600/30 dark:border-blue-400/20 relative group hover:border-blue/30 transition-all duration-500 backdrop-blur-sm">
    <div class="absolute top-0 left-0 bg-blue-600 dark:bg-blue-500 text-[9px] px-3 py-1 text-white font-mono tracking-tighter z-10 shadow-[4px_4px_0_rgba(29,78,216,0.2)]">UNIT_02 // FRAME</div>
    
    <div class="flex flex-row items-center border-b border-blue-600/30 dark:border-blue-400/20 pb-6 mb-2">
      <div class="p-2 bg-zinc-500/5 mecha-panel-alt border border-blue-600/30 dark:border-blue-400/20 group-hover:scale-110 transition-transform">
        <AstroIcon />
      </div>
      <h2 class="text-rose dark:text-rose align-middle text-md md:text-xl pl-6 tracking-wide uppercase">
        {t('about.unit2')}
      </h2>
    </div>

    <div class="py-2 text-[10px] text-blue/50 font-mono uppercase tracking-widest mb-4">Structural Integrity: 100%</div>
    
    <p class="text-primary text-sm leading-relaxed opacity-80">
      {t('table.astroDesc')}
    </p>

    <div class="mt-8 flex items-end gap-1.5 h-6">
      <div class="w-12 h-1 bg-blue shadow-[0_0_10px_rgba(59,130,246,0.3)]"></div>
      <div class="w-3 h-1 bg-gold"></div>
      <div class="flex-1 h-[1px] bg-zinc-500/30 mb-[1.5px]"></div>
    </div>
  </div>

  <div class="flex-1 p-8 mecha-panel bg-zinc-500/5 border border-blue-600/30 dark:border-blue-400/20 relative group hover:border-gold/30 transition-all duration-500 backdrop-blur-sm">
    <div class="absolute top-0 left-0 bg-gold text-[9px] px-3 py-1 text-black font-mono tracking-tighter z-10 shadow-[4px_4px_0_rgba(245,158,11,0.2)]">UNIT_03 // CORE</div>
    
    <div class="flex flex-row items-center border-b border-blue-600/30 dark:border-blue-400/20 pb-6 mb-2">
      <div class="p-2 bg-zinc-500/5 mecha-panel-alt border border-blue-600/30 dark:border-blue-400/20 group-hover:scale-110 transition-transform">
        <Typescript />
      </div>
      <h2 class="text-rose dark:text-rose align-middle text-md md:text-xl pl-6 tracking-wide uppercase">
        {t('about.unit3')}
      </h2>
    </div>

    <div class="py-2 text-[10px] text-gold/50 font-mono uppercase tracking-widest mb-4">Protocol Status: Verified</div>
    
    <p class="text-primary text-sm leading-relaxed opacity-80">
      {t('table.tsDesc')}
    </p>

    <div class="mt-8 flex items-end gap-1.5 h-6">
      <div class="w-12 h-1 bg-gold shadow-[0_0_10px_rgba(245,158,11,0.3)]"></div>
      <div class="w-3 h-1 bg-zinc-500/20"></div>
      <div class="flex-1 h-[1px] bg-zinc-500/30 mb-[1.5px]"></div>
    </div>
  </div>
</section>

<style>
  h2 {
    font-family: mechsuit;
  }
</style>